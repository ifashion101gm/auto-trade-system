# =============================================================================
# Auto Trade System - Environment Configuration
# =============================================================================
# Python 3.11+ required
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control (already in .gitignore)
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# PostgreSQL (recommended for production) - Single Source of Truth
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/vmassit
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# SQLite (development/testing only) - uncomment if needed
# DATABASE_URL=sqlite+aiosqlite:///./data/vmassit.db

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------
# Required for rate limiting and caching
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Trading API Security
# -----------------------------------------------------------------------------
# Secret key for API authentication (generate a strong random string)
# Example: openssl rand -hex 32
TRADING_API_SECRET=your_bybit_api_key_here


# -----------------------------------------------------------------------------
# Bybit Trading Configuration
# -----------------------------------------------------------------------------
# Get your API keys from:
# - Testnet: https://testnet.bybit.com/ (for testing)
# - Demo Trading: https://www.bybit.com/en/trade/demo (demo mode with virtual funds)
# - Mainnet: https://www.bybit.com/en-US/my-assets/api-management (live trading)
#
# IMPORTANT: Demo Trading and Testnet are DIFFERENT environments!
# - Testnet: Uses api-testnet.bybit.com, separate account balance
# - Demo Trading: Uses api-demo.bybit.com, requires keys generated FROM demo interface

# Bybit Live Trading API Keys (Mainnet)
BYBIT_API_KEY=your_bybit_api_key_here
BYBIT_API_SECRET=your_bybit_api_secret_here

# Bybit Demo/Testnet API Keys (separate from live keys)
# Use these for both testnet AND demo trading modes
BYBIT_DEMO_API_KEY=your_bybit_demo_or_testnet_api_key_here
BYBIT_DEMO_API_SECRET=your_bybit_demo_or_testnet_api_secret_here

# Use Demo Trading Domain (api-demo.bybit.com) instead of Testnet (api-testnet.bybit.com)
# Set to true for Demo Trading keys (generated from demo mode interface)
# Set to false for Testnet keys (generated from testnet.bybit.com)
BYBIT_USE_DEMO_DOMAIN=true

# Bybit Client Configuration (Advanced)
# IMPORTANT: pybit is REQUIRED for Demo Trading support
# - Demo Trading: MUST use pybit (official SDK) - CCXT does NOT support demo mode
# - Testnet/Mainnet: Uses CCXT for unified multi-exchange interface
BYBIT_CLIENT_LIBRARY=pybit

# Rate limiting (Bybit default: 10 requests/sec for authenticated endpoints)
BYBIT_RATE_LIMIT_ENABLED=true
BYBIT_RATE_LIMIT_CALLS_PER_SECOND=10

# Trading category: "linear" (USDT perpetuals), "inverse" (coin-margined), "spot", "option"
BYBIT_CATEGORY=linear

# Request timestamp validation window in milliseconds (prevents replay attacks)
# Increase if you experience timestamp errors (10016)
BYBIT_RECV_WINDOW=5000

# -----------------------------------------------------------------------------
# Execution Mode
# -----------------------------------------------------------------------------
# Controls how trades are executed:
# - proposal: AI generates proposals only (no execution)
# - semi-auto: AI proposes, requires manual confirmation via API
# - fully-auto: AI executes trades automatically (use with caution!)
EXECUTION_MODE=semi-auto

# -----------------------------------------------------------------------------
# Telegram Notifications
# -----------------------------------------------------------------------------
# Get bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Get your chat ID from @userinfobot on Telegram
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# -----------------------------------------------------------------------------
# LLM Provider API Keys
# -----------------------------------------------------------------------------
# At least one provider should be configured for AI analysis

# OpenAI (GPT-4, GPT-4o-mini)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic (Claude Sonnet, Claude Haiku)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Google (Gemini Flash, Gemini Pro)
GOOGLE_API_KEY=AIza-your-google-api-key-here

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
# Environment: development, staging, production
APP_ENV=development

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Optional: Advanced Settings
# -----------------------------------------------------------------------------
# Daily LLM budget limit (USD)
# LLM_DAILY_Budget=2.0

# Rate limit settings (requests per minute)
# RATE_LIMIT_REQUESTS=20
# RATE_LIMIT_WINDOW=60

# Cache directory
# CACHE_DIR=./data/cache

# Backup directory
# BACKUP_DIR=./data/backups

# -----------------------------------------------------------------------------
# Docker Deployment Configuration
# -----------------------------------------------------------------------------
# These variables are used by docker-compose.yml
# IMPORTANT: Set strong passwords for production deployments!

# PostgreSQL Database
DB_USER=trading
DB_PASSWORD=CHANGE_THIS_TO_SECURE_PASSWORD
DB_NAME=vmassit

# Grafana Dashboard
GRAFANA_PASSWORD=CHANGE_THIS_TO_SECURE_PASSWORD
